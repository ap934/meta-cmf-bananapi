Source: backport
Subject: RDKBACCL-344: Bringup Telco Voice Manager in RDK-B BPI R4 router
=================================================================
Index: git/configure.ac
===================================================================
--- git.orig/configure.ac
+++ git/configure.ac
@@ -145,6 +145,16 @@ fi
 CFLAGS="$CFLAGS $PJ_PKGCONFIG_CFLAGS"
 PJ_PKGCONFIG_CFLAGS="-DPJ_AUTOCONF=1 $PJ_PKGCONFIG_CFLAGS"
 
+AC_MSG_CHECKING([whether to enable ipv6 support])
+AC_ARG_ENABLE([ipv6],
+	[AS_HELP_STRING([--enable-ipv6], [enable IPv6 support])],
+	[],[enable_ipv6=no])
+AS_IF([test x"$enable_ipv6" = xyes],[
+	CFLAGS="-DPJ_HAS_IPV6 $CFLAGS"
+	PJ_PKGCONFIG_CFLAGS="-DPJ_HAS_IPV6 $PJ_PKGCONFIG_CFLAGS"
+])
+AC_MSG_RESULT([$enable_ipv6])
+
 AC_SUBST([PJ_PKGCONFIG_CFLAGS])
 
 dnl
