Source: backport
Subject: RDKBACCL-344: Bringup Telco Voice Manager in RDK-B BPI R4 router
=================================================================
Index: git/configure.ac
===================================================================
--- git.orig/configure.ac
+++ git/configure.ac
@@ -138,10 +138,14 @@ dnl
 AC_C_BIGENDIAN
 
 if test "x$ac_cv_c_bigendian" = "xyes"; then
-  CFLAGS="$CFLAGS -DPJ_IS_BIG_ENDIAN=1 -DPJ_IS_LITTLE_ENDIAN=0"
+  PJ_PKGCONFIG_CFLAGS="-DPJ_IS_BIG_ENDIAN=1 -DPJ_IS_LITTLE_ENDIAN=0"
 else
-  CFLAGS="$CFLAGS -DPJ_IS_BIG_ENDIAN=0 -DPJ_IS_LITTLE_ENDIAN=1"
+  PJ_PKGCONFIG_CFLAGS="-DPJ_IS_BIG_ENDIAN=0 -DPJ_IS_LITTLE_ENDIAN=1"
 fi
+CFLAGS="$CFLAGS $PJ_PKGCONFIG_CFLAGS"
+PJ_PKGCONFIG_CFLAGS="-DPJ_AUTOCONF=1 $PJ_PKGCONFIG_CFLAGS"
+
+AC_SUBST([PJ_PKGCONFIG_CFLAGS])
 
 dnl
 dnl Legacy macros
